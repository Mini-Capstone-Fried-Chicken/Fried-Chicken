# Local environment variables
# This file is NEVER committed to git (see .gitignore)
# 
# Setup instructions for collaborators:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and replace the placeholder values with your actual API keys
# 3. NEVER commit .env to git - it's protected by .gitignore
#
# To get API keys:
# - Visit: https://console.cloud.google.com/
# - Create a new project or select existing one
# - Enable "Maps SDK for Android", "Places API", and "Directions API"
# - Create an API key under Credentials
# - Copy the key and paste it below

# Google Maps Directions API Key
GOOGLE_DIRECTIONS_API_KEY=YOUR_GOOGLE_DIRECTIONS_API_KEY_HERE

# Google Maps Places API Key
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY_HERE
